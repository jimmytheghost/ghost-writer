{
  "name": "ghost-writer-editor",
  "private": true,
  "version": "1.4.5",
  "type": "module",
  "scripts": {
    "check:node-version": "node scripts/check-node-version.mjs",
    "sync:models": "node scripts/sync-ollama-models.mjs",
    "dev": "vite",
    "dev:tauri": "npm run sync:models && tauri dev",
    "build": "vite build",
    "build:renderer": "vite build",
    "build:tauri": "npm run sync:models && tauri build",
    "build:tauri:win": "npm run sync:models && tauri build --target x86_64-pc-windows-msvc --bundles nsis",
    "build:tauri:mac": "npm run sync:models && node scripts/build-tauri-mac.mjs",
    "lint": "eslint .",
    "test": "node scripts/run-vitest.mjs",
    "test:run": "node scripts/run-vitest.mjs run",
    "preview": "vite preview",
    "precheck": "npm run check:node-version",
    "check": "npm run lint && npm run test:run && npm run build",
    "metrics:renderer": "npm run build:renderer",
    "metrics:package": "node scripts/measure-package-size.mjs",
    "metrics:tauri": "node scripts/measure-tauri-size.mjs"
  },
  "engines": {
    "node": ">=20.19.0 <21 || >=22.12.0"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "dictionary-en-us": "^2.2.1",
    "markdown-it": "^14.1.1",
    "markdown-it-attrs": "^4.3.1",
    "markdown-it-deflist": "^3.0.0",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-sub": "^2.0.0",
    "markdown-it-sup": "^2.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "nspell": "^2.1.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tauri-apps/cli": "^2.10.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^22.1.0",
    "vite": "^7.2.4",
    "vitest": "^3.2.4"
  }
}
