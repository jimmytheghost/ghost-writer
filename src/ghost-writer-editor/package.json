{
  "name": "ghost-writer-editor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "electron-vite dev",
    "dev:tauri": "tauri dev",
    "build": "vite build",
    "build:renderer": "vite build",
    "build:electron": "electron-vite build",
    "build:tauri": "tauri build",
    "build:tauri:win": "tauri build --target x86_64-pc-windows-msvc --bundles nsis",
    "build:tauri:mac": "tauri build --target x86_64-apple-darwin --bundles dmg",
    "dist:win": "npm run build:electron && electron-builder --win nsis --x64",
    "dist:mac": "npm run build:electron && electron-builder --mac dmg --x64",
    "dist": "npm run build:electron && electron-builder --win nsis --x64 --mac dmg --x64",
    "lint": "eslint .",
    "test": "vitest",
    "test:run": "vitest run",
    "preview": "vite preview",
    "check": "npm run lint && npm run test:run && npm run build",
    "metrics:renderer": "npm run build:renderer",
    "metrics:package": "node scripts/measure-package-size.mjs",
    "metrics:tauri": "node scripts/measure-tauri-size.mjs"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "build": {
    "extends": "./electron-builder.yml"
  },
  "dependencies": {
    "marked": "^12.0.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@tauri-apps/cli": "^2.10.0",
    "electron": "^33.3.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^22.1.0",
    "vite": "^7.2.4",
    "vitest": "^3.2.4"
  }
}
