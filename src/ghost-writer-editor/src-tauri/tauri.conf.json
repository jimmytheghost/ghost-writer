{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ghost Writer",
  "version": "0.1.2",
  "identifier": "com.ghostwriter.editor",
  "build": {
    "beforeDevCommand": "npm run dev -- --host",
    "devUrl": "http://localhost:5174",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ghost Writer",
        "width": 400,
        "height": 500,
        "minWidth": 400,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "dmg"
    ],
    "category": "Productivity",
    "createUpdaterArtifacts": false,
    "windows": {
      "nsis": {}
    },
    "icon": [
      "icons/icon.png"
    ]
  }
}
