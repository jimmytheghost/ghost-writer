{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ghost Writer",
  "version": "0.1.3",
  "identifier": "com.ghostwriter.editor",
  "build": {
    "beforeDevCommand": "npm run dev -- --host",
    "devUrl": "http://localhost:5174",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ghost Writer",
        "width": 400,
        "height": 500,
        "minWidth": 400,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": "default-src 'self'; base-uri 'self'; form-action 'none'; object-src 'none'; frame-src 'none'; connect-src 'self' ipc: http://ipc.localhost http://localhost:11434 http://127.0.0.1:11434; img-src 'self' asset: data: https: http:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "dmg"
    ],
    "category": "Productivity",
    "createUpdaterArtifacts": false,
    "windows": {
      "nsis": {}
    },
    "icon": [
      "icons/icon.png"
    ]
  }
}
