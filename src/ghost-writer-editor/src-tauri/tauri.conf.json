{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ghost Writer",
  "version": "1.5.2",
  "identifier": "com.ghostwriter.editor",
  "build": {
    "beforeDevCommand": "npm run dev -- --host",
    "devUrl": "http://localhost:5174",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ghost Writer",
        "width": 600,
        "height": 900,
        "minWidth": 430,
        "minHeight": 560,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; base-uri 'self'; form-action 'none'; object-src 'none'; frame-src 'none'; connect-src 'self' ipc: http://ipc.localhost http: https:; img-src 'self' asset: file: data: https: http:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; script-src 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "dmg"
    ],
    "category": "Productivity",
    "createUpdaterArtifacts": false,
    "windows": {
      "nsis": {}
    },
    "icon": [
      "icons/icon.png"
    ]
  }
}
