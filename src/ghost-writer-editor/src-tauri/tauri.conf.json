{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ghost Writer",
  "version": "0.1.0",
  "identifier": "com.ghostwriter.editor",
  "build": {
    "beforeDevCommand": "npm run dev -- --host",
    "devUrl": "http://localhost:5174",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Ghost Writer",
        "width": 1280,
        "height": 860,
        "minWidth": 500,
        "minHeight": 640,
        "transparent": true,
        "backgroundColor": "#00000000",
        "windowEffects": {
          "effects": [
            "underWindowBackground",
            "hudWindow"
          ],
          "state": "active"
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "dmg"
    ],
    "category": "Productivity",
    "createUpdaterArtifacts": false,
    "windows": {
      "nsis": {}
    },
    "icon": [
      "../dist/ghost-writer-logo.png"
    ]
  }
}
